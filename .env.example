# Required
CLIPPINGBOT_OBSIDIAN_VAULT=/data/obsidian
CLIPPINGBOT_CRAWL4AI_BASE_URL=http://crawl4ai:11235
CLIPPINGBOT_CRAWL4AI_EMAIL=you@example.com

# Recommended for your NAS deployment
CLIPPINGBOT_FEISHU_DELIVERY_MODE=longconn
CLIPPINGBOT_FEISHU_APP_ID=
CLIPPINGBOT_FEISHU_APP_SECRET=
CLIPPINGBOT_FEISHU_ENCRYPT_KEY=
CLIPPINGBOT_FEISHU_REPLY_ENABLED=true
CLIPPINGBOT_FEISHU_REPLY_RECEIVE_ID_TYPE=chat_id

# Optional note behavior
CLIPPINGBOT_OBSIDIAN_INBOX=Clippings
CLIPPINGBOT_CRAWL4AI_FILTER=fit
CLIPPINGBOT_CRAWL4AI_TIMEOUT_SECONDS=60
CLIPPINGBOT_CRAWL4AI_MODE=auto
CLIPPINGBOT_CRAWL4AI_CRAWL_FALLBACK_DOMAINS=mp.weixin.qq.com
CLIPPINGBOT_NOTE_TAGS=clippings,inbox
CLIPPINGBOT_NOTE_OVERWRITE_EXISTING=true
CLIPPINGBOT_FILENAME_MAX_LENGTH=72

# Optional webhook compatibility mode
CLIPPINGBOT_FEISHU_VERIFY_TOKEN=
CLIPPINGBOT_HOST=0.0.0.0
CLIPPINGBOT_PORT=8787
